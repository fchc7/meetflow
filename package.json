{
  "name": "meetflow",
  "private": true,
  "version": "0.0.1",
  "description": "Meeting management system",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:web": "pnpm --filter @meetflow/web dev",
    "dev:server": "pnpm --filter @meetflow/server dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1"
  }
}
